// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Propuestas de proveedores recibidas por el chatbot
model PropuestaProveedor {
  id            String   @id @default(cuid())
  empresa       String                        // Nombre de la empresa o tipo de servicio
  descripcion   String                        // Descripción del producto/servicio
  sitioWeb      String                        // Link o página web de la propuesta
  contacto      String                        // Teléfono y/o correo del proveedor
  sessionId     String?                       // ID de la sesión del chat
  revisada      Boolean  @default(false)      // Si el área de compras ya la revisó
  notas         String?                       // Notas internas del área de compras
  creadaEn      DateTime @default(now())      // Fecha/hora de recepción
  actualizadaEn DateTime @updatedAt
}